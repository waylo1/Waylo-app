# Backend Fastify (proxy /api/* — cf. next.config.ts)
API_URL=http://localhost:3000

# Clé publishable Stripe (mode test) — requise pour /missions/:id/pay
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Capture d'erreurs (SDK léger maison) — désactivée par défaut.
NEXT_PUBLIC_ERROR_REPORTING_ENABLED=false
NEXT_PUBLIC_ERROR_DSN=
