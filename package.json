{
  "name": "waylo-api",
  "version": "0.1.0",
  "private": true,
  "description": "Waylo — webhooks Stripe (escrow missions, autorisation JIT Issuing), worker de transfert outbox, réconciliation",
  "engines": {
    "node": ">=20"
  },
  "//workspaces": "Monorepo (MOB-00) : le backend reste le paquet racine (Dockerfile/fly/CI/chemin Prisma y sont couplés). packages/* = @waylo/shared (SSOT) + @waylo/mobile (Expo). frontend/ reste hors workspaces (lockfile + étape CI dédiés).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --force",
    "typecheck": "tsc --noEmit",
    "reconcile": "tsx src/scripts/trigger-reconciliation.ts",
    "test": "vitest run",
    "test:e2e": "tsx scripts/e2e-smoke.mts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "10.0.0",
    "@prisma/client": "5.22.0",
    "argon2": "^0.44.0",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "stripe": "^17.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pino": "^7.0.4",
    "pino-pretty": "^13.1.3",
    "prisma": "5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "fast-uri": "^3.1.2"
  }
}
