// Waylo — schema.prisma
// Règles : tout montant en Int (centimes), jamais Float/Decimal (rules.md §3).
// @unique génère déjà un index B-tree unique en PostgreSQL ; @@index explicites sur les FK.
// Receipt et IssuingAuthorizationLog sont immuables : pas d'updatedAt, pas de soft-delete.

generator client {
  provider = "prisma-client-js"
  // Sortie dédiée : ne pas écraser le client FlipSync (packages/db) hoisté dans node_modules/.prisma
  output   = "../src/generated/prisma"
  // metrics : expose prisma.$metrics.json() (jauges du pool de connexions) — lu en
  // lecture seule par GET /debug/performance. Feature CLIENT-ONLY : aucune migration DB.
  previewFeatures = ["metrics"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum MissionStatus {
  CREATED
  FUNDED // escrow en place : PaymentIntent (capture différée) créé, EscrowTransaction HELD
  MATCHED
  IN_PROGRESS
  ESCROW_LOCKED_CUSTOMS // valeur déclarée > seuil douanier : verrou initial posé par /receive
  PENDING_CUSTOMS_REVIEW // quittance déposée par le voyageur : en attente de validation ops/admin (le bénéficiaire ne lève pas son propre verrou)
  AWAITING_VALIDATION
  VALIDATED // acheteur a validé (T1) : capture du PaymentIntent déclenchée — état transitoire, le webhook payment_intent.succeeded finalise en RELEASED
  DEPOSITED // le voyageur a déposé/remis le colis (preuve de dépôt + tracking) ; atteint depuis MATCHED ou VALIDATED (post-douane) via /dropoff-receipt
  DISPUTED // litige ouvert par l'acheteur depuis DEPOSITED (/dispute) ; GÈLE la mission : retirée des workers de timeout (capture/refund auto), résolution humaine requise
  IN_DISPUTE // litige AUTOMATISÉ (DisputeService.openDispute) : aucune intervention humaine. Gèle le payout (garde escrowPayoutWorker) ; à `disputeDeadline` (now + 72 h) atteinte, DisputeResolutionWorker déclenche un REFUND Stripe via OutboxEvent READY_FOR_REFUND → REFUNDED. Distinct de DISPUTED (arbitrage humain).
  DISPUTED_FRAUD // arbitrage admin : vol/fraude voyageur avéré (depuis DISPUTED) — état gelé terminal ; déclenche la ponction 200% (PenaltyDebitOutbox) + journalisation compensation acheteur 120% (LedgerEntry). Aucune libération, aucun versement voyageur.
  AWAITING_TRAVELER_ACCOUNT // capture journalisée, versement impossible (compte Connect absent/non vérifié) — intervention requise
  RELEASED
  REFUNDED
  CANCELLED
  EXPIRED // « ghost mission » : CREATED jamais financée et expiresAt dépassé — clôturée par le worker mission-lifecycle (aucun escrow, aucun argent en jeu)
  AWAITING_CONFIRMATION // colis livré : en attente de la confirmation de réception de l'acheteur (preuve de livraison). Gèle la suppression de compte des parties (userService.deleteAccount).
  COMPLETED_BY_BUYER // acheteur a confirmé la réception (deliveryProof vérifié) : déclenche le paiement voyageur via OutboxEvent READY_FOR_PAYOUT (capture exécutée hors tx par le worker).
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED // PaymentIntent échoué (payment_intent.payment_failed) : hold jamais capturé → annulé
}

enum DisputeStatus {
  DRAFT
  OPEN
  ESCALATED
  RESOLVED
  CLOSED
}

enum LedgerType {
  CAPTURE
  PAYOUT
  COMMISSION
  REFUND
  BUYER_WALLET_CREDIT // reliquat de substitution « Drive » (S18) : part du séquestre capturé NON dépensée en magasin, recréditée au Wallet interne acheteur. INCLUS dans les invariants B/C (décompose la capture : CAPTURE = PAYOUT + COMMISSION + BUYER_WALLET_CREDIT) — zéro décaissement Stripe.
  FRAUD_PENALTY_COLLECTED // ponction du voyageur fraudeur : 200% de (Valeur Objet + Frais Service). Flux SÉPARÉ de l'escrow acheteur — EXCLU des invariants A/B/C (la réconciliation ne somme que CAPTURE/PAYOUT/COMMISSION/REFUND).
  BUYER_REFUND_COMPENSATION // compensation versée à l'acheteur : 120% de (Valeur Objet + Frais Service), financée par la ponction. EXCLUE des invariants A/B/C — magnitude positive, le TYPE porte la direction (sortie vers l'acheteur).
}

enum TransferStatus {
  PENDING
  SUBMITTED
  SETTLED
  FAILED
  ABANDONED // terminal : M tentatives épuisées (échec structurel) — hors scope worker et requeue, « needs human »
}

// Cycle de vie de l'outbox de COMPENSATION ACHETEUR (restitution 120% de fraude, roadmap S20+).
// Volontairement plus court que TransferStatus : pas de SUBMITTED/ABANDONED tant que le
// worker dédié n'existe pas — ces valeurs seront ajoutées par `ADD VALUE` (rétro-compatible)
// quand le claim FOR UPDATE SKIP LOCKED et l'abandon M-tentatives seront implémentés.
enum OutboxStatus {
  PENDING
  SETTLED
  FAILED
}

// Cycle de vie d'un job d'extraction OCR de reçu (outbox dédiée). Distinct de
// OutboxStatus : un job traverse un état PROCESSING explicite (appel Vision en
// cours, hors transaction DB) entre la prise en charge et le verdict final.
// COMPLETED = extraction réussie ; CONSUMED = reçu validé (anti-fraude : total OCR
// == purchaseAmountCents) PUIS scellé (Receipt créé) ; FAILED = échec d'extraction
// OU rejet métier (montant manquant / mismatch / reçu déjà scellé).
enum ReceiptJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  CONSUMED
  FAILED
}

// Type d'événement métier de l'outbox générique (OutboxEvent). READY_FOR_PAYOUT :
// l'acheteur a confirmé la réception → handoff vers le worker de paiement (capture
// Stripe HORS transaction DB — règle « No Stripe in DB tx »).
enum OutboxEventType {
  READY_FOR_PAYOUT
  // Litige automatisé : `disputeDeadline` atteinte → DisputeResolutionWorker enfile
  // ce fait métier ; le consommateur annule le hold Stripe HORS transaction DB
  // (paymentIntents.cancel), puis mission → REFUNDED. Pattern outbox = règle d'or
  // « aucun appel Stripe dans une transaction DB ».
  READY_FOR_REFUND
}

enum SubstitutionStatus {
  PENDING
  APPROVED
  REJECTED
  ITEM_SKIPPED
}

// Statut de la preuve de livraison (deliveryProofStatus sur Mission). Source de
// vérité pour déclencher la pénalité d'instruction : seul VALIDATED autorise la
// création d'une Penalty (contrainte « pas de prélèvement sans preuve »).
enum DeliveryProofStatus {
  PENDING   // aucune preuve déposée ou en cours de validation
  VALIDATED // preuve de livraison acceptée — contestation potentiellement abusive
  REJECTED  // preuve rejetée — litige légitime, aucune pénalité
}

// Motif d'une pénalité d'instruction (frais réels d'investigation technique :
// logs certifiés eIDAS, preuves GPS…). Distinct de la ponction de FRAUDE 200%
// (PenaltyDebitOutbox) : ici frais FIXES facturés à l'auteur d'une contestation
// MANIFESTEMENT ABUSIVE (après validation conforme du protocole de preuve).
enum PenaltyReason {
  ABUSIVE_CONTESTATION // contestation déclarée abusive après validation de la preuve de livraison
}

// Cycle de vie de l'outbox de pénalité d'instruction : PENDING (intention commitée
// avec la résolution du litige) → PAID (prélèvement Stripe abouti) | FAILED
// (prélèvement épuisé après retries → suspension automatique du compte).
enum PenaltyStatus {
  PENDING
  PAID
  FAILED
}

// État de compte utilisateur. SUSPENDED = blacklist automatique posée par le
// disputePenaltyWorker quand le prélèvement de la pénalité d'instruction échoue
// définitivement (carte refusée/absente). Réversible par les ops (retour ACTIVE).
enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum AuthDecision {
  APPROVED
  DECLINED
}

enum DropOffType {
  LOCKER  // casier automatique (InPost, DHL Packstation…)
  RELAY   // point relais commerçant (Mondial Relay, UPS Access Point…)
  POSTAL  // dépôt bureau de poste / service postal standard
}

model User {
  id               String    @id @default(cuid())
  // Pas de rôle de compte : « acheteur » / « voyageur » est CONTEXTUEL, dérivé
  // des relations Mission (buyerId / travelerId). Un même User peut être les deux.
  email            String    @unique
  passwordHash     String? // argon2 — null : compte créé hors register (seed, futur OAuth) → login refusé
  isAdmin          Boolean   @default(false) // flag ops/admin (source de vérité unique, auditable) — remplace l'allowlist ADMIN_USER_IDS via env
  accountStatus    AccountStatus @default(ACTIVE) // ACTIVE par défaut ; SUSPENDED = blacklist auto posée par disputePenaltyWorker sur échec définitif du prélèvement de pénalité d'instruction
  kycStatus        KycStatus @default(PENDING)
  stripeCustomerId String?   @unique // acheteur (réutilisé comme customer de garantie côté voyageur)
  stripeAccountId  String?   @unique // voyageur (Connect)
  stripePaymentMethodId String? @unique // carte de garantie voyageur (pm_…), vérifiée à l'inscription : adosse la future ponction de pénalité ; requise pour accepter/prendre une mission
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  missionsAsBuyer    Mission[] @relation("BuyerMissions")
  missionsAsTraveler Mission[] @relation("TravelerMissions")
  adminAuditLogs     AdminAuditLog[]
  reviewsAuthored    Review[]  @relation("ReviewsAuthored")
  reviewsReceived    Review[]  @relation("ReviewsReceived")
  penaltyDebits      PenaltyDebitOutbox[]
  wallet             Wallet?   // solde interne acheteur (reliquat de substitution « Drive », S18)
  buyerCompensations BuyerCompensationOutbox[] // restitutions 120% de fraude en attente d'exécution (roadmap S20+)
  receiptExtractions ReceiptExtractionOutbox[] // reçus déposés par ce voyageur, en file d'extraction OCR (S21)
  disputesOpened     Dispute[] // litiges ouverts par cet utilisateur (DisputeService)
  penalties          Penalty[] // pénalités d'instruction (contestation abusive) facturées à cet utilisateur
}

model Mission {
  id              String        @id @default(cuid())
  buyerId         String
  travelerId      String?
  status          MissionStatus @default(CREATED)
  targetProduct   String
  budgetCents     Int // figé après MATCHED — toute modification post-MATCHED est interdite côté service
  commissionCents Int // figé
  substitutionAuthorized Boolean @default(false) // pré-autorisation acheteur (modèle « Drive », S16) : le voyageur peut sceller un reçu > budget jusqu'à 120% sans attente synchrone ; défaut false = comportement historique (reçu > budget refusé)
  origin          String   @default("") // lieu d'origine (acheteur) ; @default("") pour backfill des lignes existantes — jamais vide via l'API (validation min 1)
  destination     String
  trackingReference String? // référence de suivi du dépôt/expédition (posée à MATCHED → IN_PROGRESS via /ship)
  purchaseAmountCents Int? // montant d'achat réel scellé par le voyageur à /ship — base du contrôle douanier (anti sous-déclaration via budget)
  destinationCountry String? // code pays ISO-2 destination (seuil douanier) ; null = pas de contrôle douanier
  customsReceiptUrl  String? // preuve de paiement des taxes (posée par le voyageur via /customs-receipt) ; null = non fournie
  customsReceiptSha256 String? // scellé serveur de la quittance douanière
  saleSignature   String? // sha256 du certificat de revente (généré à la confirmation de réception, /receive)
  dropoffReceiptUrl    String?   // preuve de dépôt du colis par le voyageur (posée via /dropoff-receipt) ; null = pas encore déposé
  dropoffTrackingNumber String?  // numéro de suivi optionnel du dépôt (transporteur)
  dropoffAt            DateTime? // horodatage serveur du dépôt (jamais l'horloge du device)
  dropOffType          DropOffType? // mode de dépôt logistique (posé via /drop-off depuis IN_PROGRESS)
  dropOffCarrier       String?      // nom du transporteur / réseau (ex: "InPost", "La Poste")
  dropOffTrackingId    String?      // numéro de colis ou identifiant de casier
  dropOffAccessCode    String?      // code secret optionnel pour ouvrir le casier / retirer le colis
  droppedAt            DateTime?    // horodatage serveur du dépôt logistique (jamais l'horloge du device)
  disputeReason        String?   // motif du litige acheteur (optionnel) ; null hors litige
  disputedAt           DateTime? // horodatage serveur d'ouverture du litige (/dispute) ; null hors litige
  disputeOpenedAt      DateTime? // litige AUTOMATISÉ (IN_DISPUTE) : horodatage serveur d'ouverture (DisputeService.openDispute) ; null hors litige auto
  disputeDeadline      DateTime? // litige AUTOMATISÉ : échéance (disputeOpenedAt + 72 h) ; passée, DisputeResolutionWorker déclenche le REFUND auto. null hors litige auto
  isContestAbusive     Boolean   @default(false) // DÉPRÉCIÉ — remplacé par deliveryProofStatus ; conservé pour rétrocompatibilité mais plus lu par les workers.
  deliveryProofStatus  DeliveryProofStatus @default(PENDING) // source de vérité pour la pénalité d'instruction : VALIDATED = livraison prouvée → contestation potentiellement abusive ; PENDING = défaut = bonne foi (aucune pénalité). Posé par le protocole de preuve (ops/admin).
  deliveryProofHash    String?   // sha256 (hex) de la preuve de livraison scellée à confirmReception ; jamais le secret en clair (preuve irréfutable de litige)
  receptionConfirmedAt DateTime? // horodatage serveur de la confirmation de réception acheteur (confirmReception) ; null tant que non confirmé
  innerQrCodeHash      String?   // sha256 (hex) du QR scellé À L'INTÉRIEUR du colis : preuve anti-« colis vide ». Waylo ne stocke QUE le hash ; l'acheteur scanne le code brut à la réception, /confirm-collection le vérifie (timingSafeEqual) avant de libérer le séquestre. null = mission sans sceau (chemin de collecte historique)
  version         Int           @default(0) // Optimistic concurrency — incrémenté à chaque mutation de statut par l'acheteur (/validate, /confirm-receipt)
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  buyer    User  @relation("BuyerMissions", fields: [buyerId], references: [id])
  traveler User? @relation("TravelerMissions", fields: [travelerId], references: [id])

  escrow          EscrowTransaction?
  substitutions   SubstitutionRequest[]
  receipt         Receipt?
  issuingAuthLogs IssuingAuthorizationLog[]
  reviews         Review[]
  penaltyDebit    PenaltyDebitOutbox?
  walletTransaction WalletTransaction? // crédit Wallet acheteur du reliquat de substitution (S18) — au plus un par mission
  buyerCompensations BuyerCompensationOutbox[] // intentions de compensation 120% (arbitrage de fraude, roadmap S20+)
  receiptExtractions ReceiptExtractionOutbox[] // jobs d'extraction OCR de reçu (upload voyageur, S21)
  outboxEvents    OutboxEvent[] // événements métier asynchrones (ex. READY_FOR_PAYOUT à confirmReception, S22)
  dispute         Dispute? // litige structuré (cycle de vie DisputeService) — au plus un par mission
  penalty         Penalty? // pénalité d'instruction (contestation abusive) — au plus une par mission

  @@index([buyerId])
  @@index([travelerId])
  // (status, expiresAt) sert À LA FOIS le sweep mission-lifecycle (status=CREATED AND
  // expiresAt < now) ET les filtres de statut seuls (catalogue FUNDED, customs-pending…)
  // via son préfixe gauche — un index simple [status] serait redondant.
  @@index([status, expiresAt])
}

model EscrowTransaction {
  id                    String       @id @default(cuid())
  missionId             String       @unique
  stripePaymentIntentId String       @unique
  capturedAmountCents   Int          @default(0) // 0 = pas encore capturé ; peuplé au MOMENT de la capture réelle (payment_intent.succeeded), jamais à la libération
  status                EscrowStatus @default(HELD)
  stripeIssuingCardId   String?      @unique // lecture indexée du webhook JIT (chemin critique < 2 s)
  spendingLimitCents    Int // = budget mission, figé ; aucun champ pour ramener la carte à 0 € post-autorisation
  idempotencyKey        String       @unique
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  mission       Mission          @relation(fields: [missionId], references: [id])
  ledgerEntries LedgerEntry[]
  transfers     TransferOutbox[]
}

// Outbox transactionnel : l'intention de versement commit AVEC la ligne PAYOUT
// (même transaction DB), l'exécution Stripe est portée par le worker — SEUL
// chemin qui appelle transfers.create. Aucun appel Stripe dans une transaction DB.
model TransferOutbox {
  id                   String         @id @default(cuid())
  escrowId             String
  stripeTransferId     String?        @unique
  destinationAccountId String
  amountCents          Int
  status               TransferStatus @default(PENDING)
  idempotencyKey       String         @unique // dérivée de l'escrowId — un seul transfert de libération par escrow
  attempts             Int            @default(0)
  lastError            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  escrow EscrowTransaction @relation(fields: [escrowId], references: [id])

  @@index([status])
  @@index([escrowId])
}

// Outbox transactionnel de la PONCTION DE PÉNALITÉ (vol/fraude voyageur, Sprint 14).
// L'intention de débit de la carte de garantie du voyageur (`User.stripePaymentMethodId`)
// commit AVEC la décision d'arbitrage (même $transaction que la transition + le ledger).
// L'exécution Stripe réelle (charge off-session de la carte) sera portée par un worker
// dédié — JAMAIS dans une transaction DB (règle d'or). Une seule ponction par mission
// (@unique) : idempotence stricte, miroir de l'unicité TransferOutbox par escrow.
model PenaltyDebitOutbox {
  id          String         @id @default(cuid())
  missionId   String         @unique // une seule ponction par mission (idempotence)
  userId      String // voyageur fraudeur dont la carte de garantie sera débitée
  amountCents Int // (Valeur Objet + Frais Service) * 2 = 200%, centimes Int
  status      TransferStatus @default(PENDING) // réutilise le cycle outbox PENDING → SUBMITTED → SETTLED|FAILED|ABANDONED
  // PI de la charge off-session de la carte voyageur (peuplé à SETTLED). @unique :
  // un seul débit Stripe réussi par ponction — miroir de TransferOutbox.stripeTransferId.
  stripePaymentIntentId String? @unique
  attempts    Int            @default(0) // backoff exponentiel : ré-éligible après 2^attempts minutes (Sprint 15)
  lastError   String? // dernière erreur Stripe (carte refusée…) — diagnostic, jamais le secret
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // onDelete: Cascade — une mission supprimée emporte son intention de ponction
  // (cohérence + isolation des tests : mission.deleteMany() ne bute pas sur la FK).
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// Outbox transactionnel de la COMPENSATION ACHETEUR (restitution 120% de fraude, roadmap S20+).
// L'intention de restituer les 120% de (Valeur Objet + Frais Service) — déjà journalisée en
// `LedgerType.BUYER_REFUND_COMPENSATION` par /arbitrate-fraud (S14) — commit ICI ; l'EXÉCUTION
// (crédit Wallet interne acheteur OU payout, canal à décider) sera portée par un worker dédié,
// JAMAIS dans une transaction DB (règle d'or). Miroir strict de TransferOutbox / PenaltyDebitOutbox
// (cycle PENDING → SETTLED | FAILED, backoff via `attempts`). Idempotence : `idempotencyKey @unique`.
model BuyerCompensationOutbox {
  id             String       @id @default(cuid())
  missionId      String
  buyerId        String // acheteur bénéficiaire de la compensation 120%
  amountCents    Int // 120% de (Valeur Objet + Frais Service), centimes Int (jamais Float)
  status         OutboxStatus @default(PENDING)
  idempotencyKey String       @unique // ex. buyer_compensation_<missionId> : une seule restitution par arbitrage
  attempts       Int          @default(0) // backoff exponentiel : ré-éligibilité du futur worker
  lastError      String? // dernière erreur d'exécution (diagnostic, jamais de secret)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // onDelete: Cascade — miroir PenaltyDebitOutbox : une mission supprimée emporte son
  // intention de compensation (cohérence + isolation des tests : mission.deleteMany()).
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@index([status]) // file d'attente du worker (éligibilité PENDING)
  @@index([buyerId])
  @@index([missionId])
}

// Outbox d'extraction OCR de reçu (S21). Un upload voyageur (POST /api/receipts/upload)
// y insère l'image NETTOYÉE (sanitizeVisionInput — métadonnées déjà retirées avant
// persistance) ; le worker `receiptOutboxWorker` la draine en réutilisant
// `processReceiptImage` (Vision → schéma → intégrité). Transitions :
//   PENDING → PROCESSING (claim atomique, committé AVANT l'appel Vision)
//           → COMPLETED (resultJson = reçu extrait) | FAILED (lastError).
// Distinct des 3 autres outbox (monétaires, OutboxStatus) : ici l'étape lourde est
// un appel réseau, jamais tenue dans une transaction DB ouverte.
model ReceiptExtractionOutbox {
  id         String           @id @default(cuid())
  missionId  String
  uploaderId String // voyageur déposant (= mission.travelerId vérifié à l'upload, anti-IDOR)
  imageData  Bytes // image JPEG/PNG nettoyée (bytea) — source de l'extraction asynchrone
  mimeType   String // 'image/jpeg' | 'image/png' détecté à l'upload (diagnostic ; le worker re-détecte)
  status     ReceiptJobStatus @default(PENDING)
  attempts   Int              @default(0) // incrémenté à chaque claim ; borne les ré-essais (échecs transitoires)
  lastError  String? // dernier code/erreur d'extraction (diagnostic, jamais de secret)
  resultJson Json? // snapshot du Receipt extrait à COMPLETED ; null tant que non traité
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // onDelete: Cascade — miroir des autres outbox : une mission supprimée emporte ses
  // jobs d'extraction (cohérence + isolation des tests : mission.deleteMany()).
  mission  Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploaderId], references: [id])

  @@index([status]) // file d'attente du worker (éligibilité PENDING + reclaim PROCESSING)
  @@index([missionId])
  @@index([uploaderId])
}

// Outbox générique d'événements métier (S22). Découple un fait métier committé en
// base (ex. acheteur a confirmé la réception) de son effet à exécuter hors
// transaction (ex. capture Stripe → paiement voyageur), porté par un worker
// asynchrone. `confirmReception` y insère READY_FOR_PAYOUT dans la MÊME transaction
// que la transition de statut → respect strict « aucun appel Stripe dans une
// transaction DB » : la $transaction ne fait QUE de l'écriture DB, jamais de réseau.
model OutboxEvent {
  id        String          @id @default(cuid())
  missionId String
  type      OutboxEventType
  status    OutboxStatus    @default(PENDING) // PENDING → SETTLED | FAILED (worker consommateur)
  payload   Json? // contexte de l'événement (ex. { deliveryProofHash, confirmedBy }) — jamais de secret en clair
  attempts  Int             @default(0)
  lastError String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // onDelete: Cascade — miroir des autres outbox : une mission supprimée emporte ses événements.
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([status]) // file d'attente du worker consommateur (éligibilité PENDING)
  @@index([missionId])
}

// Wallet interne acheteur (Sprint 18, modèle « Drive »). Solde alimenté par le
// reliquat de substitution : la part du séquestre capturé NON dépensée en magasin
// (substitutionCeilingCents(budget) − purchaseAmountCents) est recréditée ICI plutôt
// que remboursée via Stripe → zéro décaissement plateforme. `balanceCents` Int (centimes).
model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique // un seul wallet par utilisateur
  balanceCents Int     @default(0) // solde courant, centimes Int (jamais négatif : seuls des crédits ici en S18)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

// Écriture de mouvement Wallet (append-only, miroir LedgerEntry). En S18 le seul
// producteur est le reliquat de substitution à la capture. `missionId @unique` :
// idempotence stricte (un seul crédit par mission, même si le webhook rejoue).
model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  missionId   String   @unique // une seule écriture de reliquat par mission
  amountCents Int // crédit (centimes Int, positif)
  reason      String   @default("SUBSTITUTION_RESIDUAL") // motif métier (extensible)
  createdAt   DateTime @default(now())

  wallet  Wallet  @relation(fields: [walletId], references: [id])
  // onDelete: Cascade — une mission supprimée emporte son écriture wallet (isolation tests).
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model LedgerEntry {
  id          String     @id @default(cuid())
  escrowId    String
  type        LedgerType
  amountCents Int
  createdAt   DateTime   @default(now())

  escrow EscrowTransaction @relation(fields: [escrowId], references: [id])

  // Invariant : Σ(PAYOUT + COMMISSION + REFUND) == Σ(CAPTURE) par escrow.
  // Append-only : jamais d'UPDATE ni de DELETE sur une écriture comptable.

  @@index([escrowId])
}

model SubstitutionRequest {
  id                 String             @id @default(cuid())
  missionId          String
  lineItemRef        String
  proposedProduct    String
  proposedPriceCents Int
  status             SubstitutionStatus @default(PENDING) // jamais APPROVED par défaut — validation humaine obligatoire
  createdAt          DateTime           @default(now())
  resolvedAt         DateTime?

  mission Mission @relation(fields: [missionId], references: [id])

  @@index([missionId])
}

model Receipt {
  id            String   @id @default(cuid())
  missionId     String   @unique
  totalTtcCents Int
  receiptUrl    String? // URL du justificatif déposé (facultatif : antérieur au champ, reçus legacy null)
  sha256Client  String
  sha256Server  String
  sealedAt      DateTime // horloge serveur uniquement, jamais le device
  // Immuable : pas d'updatedAt — un reçu scellé ne se modifie jamais (correction = nouveau reçu)

  mission Mission @relation(fields: [missionId], references: [id])
}

model ProcessedStripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime @default(now())
}

model IssuingAuthorizationLog {
  id                    String       @id @default(cuid())
  missionId             String?
  stripeAuthorizationId String       @unique
  requestedAmountCents  Int
  decision              AuthDecision
  reason                String?
  createdAt             DateTime     @default(now())

  mission Mission? @relation(fields: [missionId], references: [id])

  // Audit KYC/AML : append-only, jamais purgé, pas de soft-delete

  @@index([missionId])
}

// Notation mutuelle après clôture de mission (statut RELEASED ou CANCELLED).
// Un auteur ne peut noter qu'une seule fois par mission (@@unique missionId+authorId).
// Immuable : pas d'updatedAt, pas de soft-delete — un avis soumis ne se modifie pas.
model Review {
  id        String   @id @default(cuid())
  missionId String
  authorId  String
  targetId  String
  rating    Int      // 1–5, validé par la route (Ajv minimum:1 maximum:5)
  comment   String?  // commentaire libre optionnel
  createdAt DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  author  User    @relation("ReviewsAuthored", fields: [authorId], references: [id])
  target  User    @relation("ReviewsReceived", fields: [targetId], references: [id])

  @@unique([missionId, authorId]) // un auteur ne note qu'une fois par mission
  @@index([missionId])
  @@index([authorId])
  @@index([targetId])
}

// Litige structuré (DisputeService) — cycle de vie immuable à transitions
// conditionnelles atomiques (anti-TOCTOU, miroir EscrowTransaction). Au plus un
// litige par mission (`missionId @unique`) ; création idempotente via
// `idempotencyKey @unique` (ex. dispute_<missionId>).
model Dispute {
  id             String        @id @default(cuid())
  missionId      String        @unique
  openedById     String // acheteur initiateur du litige
  status         DisputeStatus @default(DRAFT)
  reason         String? // motif acheteur (optionnel)
  resolution     String? // note de résolution admin
  idempotencyKey String        @unique // ex. dispute_<missionId> : un seul litige par mission
  openedAt       DateTime? // DRAFT → OPEN
  escalatedAt    DateTime? // OPEN → ESCALATED
  resolvedAt     DateTime? // → RESOLVED
  closedAt       DateTime? // RESOLVED → CLOSED (terminal)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // onDelete: Cascade — une mission supprimée emporte son litige (isolation tests).
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  opener  User    @relation(fields: [openedById], references: [id])

  @@index([openedById])
  @@index([status])
}

// Pénalité d'INSTRUCTION (frais réels d'investigation technique : logs certifiés
// eIDAS, preuves GPS…) facturée à l'auteur d'une contestation MANIFESTEMENT
// ABUSIVE. Montant FIXE en centimes Int (15000 = 150,00 € — jamais Float).
//
// DISTINCT de PenaltyDebitOutbox (ponction de FRAUDE 200% du voyageur) : cible
// l'AUTEUR du litige (acheteur), montant fixe, déclenché par DisputeResolutionWorker
// quand `Mission.isContestAbusive` = true.
//
// Pattern outbox : l'intention (PENDING) commit ATOMIQUEMENT avec la résolution du
// litige ; `disputePenaltyWorker` matérialise le prélèvement Stripe HORS transaction
// DB (charge off-session). `missionId @unique` = une seule pénalité par mission
// (idempotence stricte). Échec définitif (carte refusée/absente après retries) →
// FAILED + suspension automatique du compte (User.accountStatus = SUSPENDED).
model Penalty {
  id          String        @id @default(cuid())
  missionId   String        @unique // une seule pénalité d'instruction par mission (idempotence)
  userId      String // auteur de la contestation abusive (acheteur) dont le moyen de paiement par défaut sera prélevé
  amountCents Int           @default(15000) // frais d'instruction FIXES : 150,00 € = 15000 centimes Int (règle projet : jamais Float)
  reason      PenaltyReason
  status      PenaltyStatus @default(PENDING) // PENDING → PAID | FAILED
  // PI de la charge off-session (peuplé à PAID). @unique : un seul prélèvement
  // réussi par pénalité — miroir de PenaltyDebitOutbox.stripePaymentIntentId.
  stripePaymentIntentId String? @unique
  attempts    Int           @default(0) // incrémenté à chaque claim ; borne les retries avant FAILED + suspension
  lastError   String? // dernière erreur Stripe (carte refusée…) — diagnostic, jamais le secret
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // onDelete: Cascade — une mission supprimée emporte sa pénalité (cohérence +
  // isolation des tests : mission.deleteMany() ne bute pas sur la FK).
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  // (status, attempts) sert À LA FOIS le sweep reaper/disputePenaltyWorker (status=PENDING
  // AND attempts >= maxAttempts) ET la file d'attente du worker (status=PENDING seul) via
  // son préfixe gauche — un index simple [status] serait redondant.
  @@index([status, attempts])
}

// Origine d'une entrée d'audit. Discriminant STABLE (immunisé contre `ON DELETE SET NULL`
// sur adminId) : ADMIN = décision humaine ops/admin (adminId renseigné) ; SYSTEM = action
// automatisée d'un worker (adminId null). Ne PAS dériver l'origine de la nullité d'adminId :
// la suppression d'un compte admin nullifie adminId mais ne change PAS l'actor (l'historique
// humain ne se déguise jamais en SYSTEM).
enum AuditActor {
  ADMIN
  SYSTEM
}

model AdminAuditLog {
  id        String     @id @default(cuid())
  actor     AuditActor @default(ADMIN) // ADMIN (humain) | SYSTEM (worker) — source de vérité de l'origine, stable
  adminId   String?    // identité de l'admin humain (actor=ADMIN) ; null pour actor=SYSTEM (ou admin supprimé)
  action    String     // CUSTOMS_APPROVE | CUSTOMS_REJECT | INSTRUCTION_PENALTY_OPENED | INSTRUCTION_PENALTY_CHARGED | INSTRUCTION_PENALTY_FAILED | ACCOUNT_SUSPENDED | …
  missionId String?    // référence de mission concernée (null si action globale)
  at        DateTime   @default(now())

  admin User? @relation(fields: [adminId], references: [id])

  // Audit append-only : jamais d'UPDATE ni de DELETE.

  @@index([adminId])
  @@index([missionId])
}

// Rate-limiting DISTRIBUÉ (store Postgres) — remplace la Map en mémoire mono-process :
// partagé entre toutes les instances Fly et persistant aux redémarrages. Fenêtre fixe :
// au plus N requêtes par clé jusqu'à `expiresAt`, puis réinitialisation. Écriture par
// UPSERT atomique (INSERT … ON CONFLICT) — sûr en concurrence. Pas de FK ni d'updatedAt
// (incompatible avec l'écriture en SQL brut) ; purge possible via l'index expiresAt.
model RateLimit {
  key       String   @id // ex. "login:203.0.113.0/24:user@example.com"
  count     Int      @default(0)
  expiresAt DateTime // fin de la fenêtre courante
  createdAt DateTime @default(now())

  @@index([expiresAt]) // balayage des fenêtres expirées (purge périodique)
}
