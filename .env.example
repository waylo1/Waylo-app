# Waylo — variables d'environnement
# Copier ce fichier en `.env` et remplir les valeurs. NE JAMAIS committer `.env`.

# ── PostgreSQL (jamais SQLite : enums Prisma) ────────────────────────────────
# Dev local : conteneur Docker `flipsync-pg` exposé sur le port 5433.
# Base de dev Waylo :
DATABASE_URL="postgresql://flipsync:flipsync@localhost:5433/waylo"

# Base de TEST dédiée — les suites vitest REFUSENT de démarrer si l'URL ne
# contient pas "waylo_test" (garde-fou : les beforeAll purgent toutes les tables).
# Pour lancer les tests, utiliser :
# DATABASE_URL="postgresql://flipsync:flipsync@localhost:5433/waylo_test"

# ── Stripe ───────────────────────────────────────────────────────────────────
# Clé secrète du compte (mode test : sk_test_...). Requise au démarrage de l'app.
STRIPE_SECRET_KEY=""

# Secret de signature du webhook ASYNCHRONE  POST /api/stripe/webhook
# (payment_intent.succeeded, charge.refunded, issuing_authorization.created)
STRIPE_WEBHOOK_SECRET=""

# Secret de signature DÉDIÉ du webhook temps réel  POST /api/stripe/issuing-authorization
# (issuing_authorization.request — JIT < 2 s ; endpoint Stripe distinct, secret distinct)
STRIPE_ISSUING_WEBHOOK_SECRET=""

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret de signature des JWT (payload { sub, role }, expiration 12 h).
# Générer une valeur forte, ex. : openssl rand -hex 32
JWT_SECRET=""

# ── Optionnel ────────────────────────────────────────────────────────────────
# Fichier NDJSON append-only des alertes critiques (défaut : alerts-critical.ndjson)
# WAYLO_CRITICAL_ALERTS_FILE="alerts-critical.ndjson"
